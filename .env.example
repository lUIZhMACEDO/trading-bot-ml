# ═══════════════════════════════════════════
# Quantum Trader — Configuration
# ═══════════════════════════════════════════
# Copy this file:  cp .env.example .env
# Then fill in your keys below.
# NEVER commit .env to git!
# ═══════════════════════════════════════════

# Alpaca Paper Trading (https://app.alpaca.markets → Paper Trading → API Keys)
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# FRED Macro Data — optional, free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Trading Configuration
MAX_BUDGET=10000
MAX_POSITIONS=3
STOP_LOSS_PCT=2.0
TAKE_PROFIT_PCT=5.0
